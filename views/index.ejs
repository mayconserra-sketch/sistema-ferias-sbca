<!DOCTYPE html>
<html>
<head>
  <title>Controle de Férias SBCA</title>
  <style>
    body { font-family: Arial; background:#f4f6f9; margin:0; }
    header { background:#1e3a8a; color:white; padding:15px 30px; display:flex; justify-content:space-between; }
    .container { padding:30px; }
    table { width:100%; border-collapse:collapse; background:white; margin-top:10px; }
    th { background:#1e3a8a; color:white; padding:8px; }
    td { padding:8px; border-bottom:1px solid #ddd; }
    .alerta { background:#fff3cd; padding:15px; margin-bottom:20px; }
    .vencido { background:#f8d7da; }
  </style>
</head>
<body>

<header>
  <h2>Controle de Férias SBCA</h2>
  <div>Bem-vindo, <%= usuario %> | <a href="/logout" style="color:white;">Sair</a></div>
</header>

<div class="container">

<h3>Importar Relatório do RH</h3>
<form action="/importar" method="POST" enctype="multipart/form-data">
  <input type="file" name="arquivo" required>
  <button type="submit">Importar</button>
</form>

<% if (vencendo.length > 0) { %>
<div class="alerta">
  <strong>⚠ Períodos vencendo nos próximos 60 dias:</strong><br><br>
  <% vencendo.forEach(v => { %>
    <div>
      <%= v.nome %> - Vence em 
      <%= new Date(v.vencimento).toISOString().split('T')[0] %>
    </div>
  <% }) %>
</div>
<% } %>

<h3>Períodos Aquisitivos</h3>

<table>
<tr>
  <th>Servidor</th>
  <th>Início</th>
  <th>Fim</th>
  <th>Vencimento</th>
  <th>Saldo</th>
</tr>

<% periodos.forEach(p => { 
   const hoje = new Date();
   const venc = new Date(p.vencimento);
   const vencido = venc < hoje;
%>
<tr class="<%= vencido ? 'vencido' : '' %>">
  <td><%= p.nome %></td>
  <td><%= new Date(p.periodo_inicio).toISOString().split('T')[0] %></td>
  <td><%= new Date(p.periodo_fim).toISOString().split('T')[0] %></td>
  <td><%= new Date(p.vencimento).toISOString().split('T')[0] %></td>
  <td><%= p.saldo %></td>
</tr>
<% }) %>

</table>

</div>
</body>
</html>